v<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Boot recovery -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake & lock screen -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- App monitoring -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Voice -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Calendar (Google sign-in handles its own scope) -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <application
        android:name=".MentorApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MentorAI"
        tools:targetApi="34">

        <!-- Asosiy Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MentorAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Sessiya boshlanish ekrani — lock screen ustida -->
        <activity
            android:name=".ui.session.SessionStartActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.MentorAI.Overlay" />

        <!-- AI mentor bilan negotiation flow -->
        <activity
            android:name=".ui.negotiation.NegotiationActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.MentorAI.Overlay" />

        <!-- Hard Lock preview (dev) — sessiya boshlamasdan dizaynni ko'rish -->
        <activity
            android:name=".ui.preview.HardLockPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI.Overlay" />

        <!-- Tonggi tasdiq preview (dev) -->
        <activity
            android:name=".ui.preview.MorningConfirmPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Ertangi reja preview (dev) -->
        <activity
            android:name=".ui.preview.TomorrowPlanPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Kunlik oqim preview (dev) -->
        <activity
            android:name=".ui.preview.DayFlowPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Routine (AI rejalashtirgich) preview (dev) -->
        <activity
            android:name=".ui.preview.RoutinePreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Celebrate (haftalik bayram) preview (dev) -->
        <activity
            android:name=".ui.preview.CelebratePreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Pomodoro preview (dev) -->
        <activity
            android:name=".ui.preview.PomodoroPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Daily brief preview (dev) -->
        <activity
            android:name=".ui.preview.DailyBriefPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Session reflection preview (dev) -->
        <activity
            android:name=".ui.preview.SessionReflectionPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Stuck (turg'unlik) preview (dev) -->
        <activity
            android:name=".ui.preview.StuckPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Mentor chat preview (dev) -->
        <activity
            android:name=".ui.preview.ChatPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Urgent time preview (dev) -->
        <activity
            android:name=".ui.preview.UrgentTimePreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Rest mode preview (dev) -->
        <activity
            android:name=".ui.preview.RestModePreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Weekly review preview (dev) -->
        <activity
            android:name=".ui.preview.WeeklyReviewPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Notifications preview (dev) -->
        <activity
            android:name=".ui.preview.NotificationsPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Online class preview (dev) -->
        <activity
            android:name=".ui.preview.OnlineClassPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Add session preview (dev) -->
        <activity
            android:name=".ui.preview.AddSessionPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Profile preview (dev) -->
        <activity
            android:name=".ui.preview.ProfilePreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- DAILY FLOW DEMO — end-to-end zanjir (asosiy ilova oqimini ko'rsatadi) -->
        <activity
            android:name=".ui.demo.DailyFlowDemoActivity"
            android:exported="false"
            android:theme="@style/Theme.MentorAI" />

        <!-- Asosiy guard service -->
        <service
            android:name=".guard.FocusGuardService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Foydalanuvchi belgilagan rejaga muvofiq ilovalarni cheklash" />
        </service>

        <!-- Accessibility service -->
        <service
            android:name=".guard.AppMonitorAccessibility"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Boot receiver -->
        <receiver
            android:name=".guard.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Alarm receiver — sessiya boshlash uchun -->
        <receiver
            android:name=".guard.SessionStartReceiver"
            android:exported="false" />

        <!-- Device Admin — uninstall blokiga qarshi qatlam -->
        <receiver
            android:name=".guard.MentorDeviceAdmin"
            android:exported="true"
            android:label="@string/device_admin_label"
            android:description="@string/device_admin_description"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
